# ========================
# VERCEL FRONTEND CONFIGURATION
# ========================
# Copy this as .env.local for local development
# Vercel dashboard: add these as Environment Variables

# ========================
# BACKEND API URL
# ========================
# Development: http://127.0.0.1:8000/api/
# Production: https://your-api-domain.com/api/
REACT_APP_BACKEND_URL=http://127.0.0.1:8000/api/

# ========================
# OPTIONAL: Google Maps API Key
# ========================
# REACT_APP_GOOGLE_MAPS_API_KEY=your-key-here

# ========================
# OPTIONAL: Socket.io URL (for real-time chat)
# ========================
# REACT_APP_SOCKET_URL=http://127.0.0.1:8000
# REACT_APP_SOCKET_PATH=/socket.io

