{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm start",
  "framework": "react",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_BACKEND_URL": "@react_app_backend_url"
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
